<odoo>
  <data>
    <record id="hms_category" model="ir.module.category">
      <field name="name">HMS</field>
    </record>

    <record id="hms_users_group" model="res.groups">
      <field name="name">HMS Users</field>
      <field name="category_id" ref="hms_category"/>
    </record>

    <record id="hms_managers_group" model="res.groups">
      <field name="name">HMS Managers</field>
      <field name="category_id" ref="hms_category"/>
    </record>

    <record id="hms_user_self" model="ir.rule">
      <field name="name">HMS user patients only</field>
      <field name="model_id" ref="model_hms_patient"></field>
      <field name="groups" eval="[(4, ref('hms_users_group'))]"></field>
      <field name="domain_force">[('create_uid','=',user.id)]</field>
    </record>
  </data>
</odoo>