<odoo>
  <data>
    <record id="hms_patient_list" model="ir.ui.view">
      <field name="name">hms.patient.list</field>
      <field name="model">hms.patient</field>
      <field name="arch" type="xml">
        <tree>
          <field name="image" widget="image"/>
          <field name="first_name"/>
          <field name="last_name"/>
          <field name="email"/>
          <field name="birth_date"/>
          <field name="blood_type"/>
          <field name="state"/>
        </tree>
      </field>
    </record>

    <record id="hms_patient_form" model="ir.ui.view">
      <field name="name">hms.patient.form</field>
      <field name="model">hms.patient</field>
      <field name="arch" type="xml">
        <form>
          <header>
            <field name='state' widget ='statusbar' nolabel='1' options="{'clickable' : '1'}"/>
          </header>
          <sheet>
            <group>
              <field name="image" widget="image"/>
              <group string="Personal Information">
                <field name="first_name" required="1"/>
                <field name="last_name" required="1"/>
                <field name="email"/>
                <field name="birth_date"/>
                <field name="blood_type"/>
                <field name="address"/>
                <field name="pcr"/>
                <field name="cr_ratio" required="pcr == True"/>
                <field name="age"/>
                <field name="history" invisible="age &lt; 50"/>
              </group>
              <group string="Department Information">
                <field name="department_id" domain="[('is_opened', '=', True)]"/>
                <field name="department_capacity" readonly="True"/>
                <field name="doctors_ids" widget="many2many_tags" invisible="not department_id" groups="hms.hms_managers_group"/>
              </group>
            </group>
            <notebook>
              <page name="logs" string="Logs">
                <field name="logs" readonly="1">
                  <tree>
                    <field name="create_date"/>
                    <field name="create_uid"/>
                    <field name="description"/>
                  </tree>
                </field>
              </page>
            </notebook>
          </sheet>
        </form>
      </field>
    </record>

    <record id="hms_patient_action" model="ir.actions.act_window">
      <field name="name">Patients</field>
      <field name="res_model">hms.patient</field>
      <field name="view_mode">list,form,kanban</field>
    </record>

    <menuitem id="hms_root_menu" name="HMS"/>
    <menuitem 
      id="hms_data_menu"
      name="Data"
      parent="hms_root_menu"
    />
    <menuitem 
      id="hms_patients_menu"
      name="Patients"
      parent="hms_data_menu"
      action="hms_patient_action"
    />
  </data>
</odoo>
